<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        *{
            margin: 0;
            padding: 0;
        }
        body{
          background-color:rgb(187, 182, 255);
        }
       nav{
        color:white;
        height:40px;
        padding: 10px;
        display: flex;
        flex-direction: row;
        justify-content:space-between;
        align-items: center;
        background-color: rgb(0, 0, 0);
        position:sticky;
  top: 0;  
  z-index: 1000; 
       }
       nav ul{
        display: flex;
        list-style: none;
        gap:10px;
        align-items: center;
       }
       nav ul li{
        background-color:rgb(88, 88, 255);
        padding: 7px;
        border:1px solid white;
        border-radius: 5px;
        transition: transform 0.3s ease;
       }
       nav ul li:hover{
        transform: scale(1.05);
       }
       a{
        text-decoration: none;
        color: white;
       }
       button{
        color:white;
        background-color:black;
        padding: 7px;
        border:1px solid white;
        border-radius: 5px;
        transition: transform 0.3s ease;
       }
       button:hover{
         transform: scale(1.05);
       }
       .blog-card{
        color:white;
        width: 230px;
        height:270px;
        margin-top: 10px;
        border:1px solid white;
        border-radius: 10px;
        overflow:hidden;
        background-color: black;
        transition: transform 0.3s ease;
        position: relative;
       }
       .imgcontainer{
         width: 230px;
  height: 120px;
  overflow: hidden;
        object-fit: cover;
       
       }
       .blog-card img{
        width: 100%;
  height: 100%;
  object-fit: cover;   
  object-position: center; 
       }
       .blog-card:hover{
        transform: scale(1.05);
       }
       .blogconatiner{
        margin: 20px;
        margin-top: 0px;
        padding: 10px;
        gap:10px;
        display: grid;
       grid-template-columns: repeat(6,1fr);

       }
       .blog-card .details{
        padding: 5px;
       }
       .author{
        margin:3px 0px;
        padding:2px;
        border: 1px solid black;
       }
       h1{
        margin-left: 15px;
        margin-top: 10px;
       }
       .author{
        color:black;
        background-color: yellow;
        bottom:40px;
        position: absolute;
       }
       .rm{
        color: black;
        background-color: rgb(31, 255, 31);
        padding: 3px;
        border-radius:5px;
        bottom: 10px;
        position:absolute;
       }
    </style>
</head>
<body>
   <%- include("partials/nav", { isAuth: isAuth }) %>
   <main>
    <h1>All Blogs</h1>
    <div class="blogconatiner">
      <% blogs.forEach(blog => { %>
    <div class="blog-card">
      <% if (blog.coverPhoto) { %>
        <div class="imgcontainer">
          <img src="/uploads/<%= blog.coverPhoto %>" alt="Cover Photo">
        </div>
        

      <% } %>
      <div class="details">
        <h2><%= blog.title %></h2>
      <p><%= blog.content.substring(0, 50) %>...</p>
      <p class="author">By <b><%= blog.author ? blog.author.name : "Unknown" %></b> | <%= blog.createdAt.toDateString() %></p>
      <a class="rm" href="/api/blog/fullblog/<%= blog._id %>">Read More</a>
      </div>
      
    </div>
  <% }) %>
    </div>
  
   </main>
</body>
</html>